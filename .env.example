# Copy to .env and fill in values

# PostgreSQL — get from Supabase dashboard (Settings > Database > Connection string)
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# balldontlie.io — free API key at https://www.balldontlie.io
BALLDONTLIE_API_KEY=""

# NOTE: Play-by-play data
# Option A (free, unofficial): nba.com/stats CDN — no key needed, may break
# Option B (licensed): SportRadar NBA API — https://sportradar.com/apis/nba/
# Option C: Keep using mock data in app/lib/mock-data.ts
SPORTRADAR_API_KEY=""
