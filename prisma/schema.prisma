generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  displayName   String
  bio           String?
  avatarUrl     String?
  favoriteTeams String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviews     Review[]
  playRatings PlayRating[]
  likes       ReviewLike[]
  following   Follow[]     @relation("follower")
  followers   Follow[]     @relation("following")
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Review {
  id        String   @id @default(cuid())
  // balldontlie.io game ID — integer
  gameId    Int
  userId    String
  rating    Int // 1-5
  text      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes ReviewLike[]

  @@unique([gameId, userId]) // one review per user per game
  @@index([gameId])
  @@index([userId])
}

model ReviewLike {
  reviewId String
  userId   String

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([reviewId, userId])
}

model PlayRating {
  id        String   @id @default(cuid())
  gameId    Int
  // NOTE: playId comes from the play-by-play data source.
  // With nba.com stats: actionNumber field. With SportRadar: event_id.
  playId    String
  userId    String
  rating    Int // 1-5
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([playId, userId])
  @@index([gameId])
}
